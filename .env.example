# Neon connection string (Neon dashboard -> Connect). Set in Vercel env vars.
DATABASE_URL=postgresql://user:pass@host/db

# Any long random string. Signs the login tokens (JWT). Set in Vercel.
JWT_SECRET=change-me-to-a-long-random-string

# Any password you choose. Protects the demo-data seeding endpoint. Set in Vercel.
SEED_SECRET=choose-a-seed-password
